# Docker Environment Configuration
# Copy this to .env.docker and fill in your values
# Usage: docker-compose --env-file .env.docker up

# Required: OpenAI API Key
OPENAI_API_KEY=sk_your_api_key_here

# Environment: development or production
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Optional: Tesseract Path (if custom installation)
# PYTESSERACT_PATH=/usr/bin/tesseract

# Logging Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: Azure OpenAI (if using instead of OpenAI)
# AZURE_OPENAI_API_KEY=your_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name
